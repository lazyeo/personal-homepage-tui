# ═══════════════════════════════════════════════════════════════
# Personal Homepage TUI Environment Variables
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# SERVER-SIDE AI CONFIGURATION (Cloudflare Pages Functions)
# ───────────────────────────────────────────────────────────────
# Configure these in Cloudflare Pages → Settings → Environment variables.
# Do NOT prefix API keys with PUBLIC_. PUBLIC_ variables are exposed to browsers.

# Provider: gemini | openai | anthropic
AI_PROVIDER=openai

# Base URL is optional for official providers.
# OpenAI-compatible default: https://api.openai.com
# Gemini default: https://generativelanguage.googleapis.com
# Anthropic default: https://api.anthropic.com
# For GPT-compatible relays, set your relay base URL here. A trailing /v1 is OK.
AI_BASE_URL=https://api.openai.com

# Server-only API key. Never expose this as PUBLIC_AI_API_KEY.
AI_API_KEY=your_server_side_api_key_here

# Model name accepted by the configured provider/relay.
AI_MODEL=gpt-3.5-turbo

# Optional server-side cost control for /api/chat.
# Defaults: 20 requests per IP/user-agent bucket per hour.
CHAT_RATE_LIMIT_MAX_REQUESTS=20
CHAT_RATE_LIMIT_WINDOW_SECONDS=3600
# Optional stable random salt for hashing rate-limit fingerprints in KV.
CHAT_RATE_LIMIT_SALT=
# Optional comma-separated IP allowlist that bypasses chat rate limiting.
# Useful for trusted local testing; leave empty to test rate-limit behavior.
CHAT_RATE_LIMIT_BYPASS_IPS=

# ───────────────────────────────────────────────────────────────
# SERVER-SIDE PUBLIC PORTFOLIO CONTEXT
# ───────────────────────────────────────────────────────────────
# Bind a Cloudflare KV namespace to Pages Functions with this binding name:
#   PORTFOLIO_CONTEXT
# Store the public context markdown at this key:
PORTFOLIO_CONTEXT_KEY=portfolio_context:latest

# ───────────────────────────────────────────────────────────────
# PUBLIC FRONTEND CONFIGURATION
# ───────────────────────────────────────────────────────────────
# Cloudflare Web Analytics (optional)
# Get token from: Cloudflare Dashboard → Analytics & Logs → Web Analytics → Add Site
PUBLIC_CF_ANALYTICS_TOKEN=
